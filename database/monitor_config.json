{
    "// Monitor / GUI config — online server, display histograms, diagnostics.": "",
    "// Sister files: daq_config.json (DAQ + raw decoding), reconstruction_config.json": "",
    "// (cluster/hit reconstruction + runinfo).  Loaded by prad2_server -c.": "",

    "online": {
        "et_host": "clondaq2",
        "et_port": 11111,
        "et_file": "/et/clasprod",
        "et_station": "prad2_monitor",
        "ring_buffer_size": 20,
        "refresh_ms": {
            "event": 200,
            "ring": 500,
            "histogram": 2000,
            "lms": 2000
        }
    },
    "waveform": {
        "accept_trigger_bits": [],
        "reject_trigger_bits": ["Pulser"],
        "// filter applies to all Waveform-Tab histograms when the GUI 'apply' toggle is on.": "",
        "// Each axis (time/integral/height) is optional; omit a min/max to drop that side.": "",
        "// quality_bits.{accept,reject} reference the Q_PEAK_* palette in /api/config.": "",
        "filter": {
            "time": {"min": 80, "max": 280}
        },
        "height_hist": {
            "min": 0, "max": 4000, "step": 10,
            "ref_lines": [
                {"axis": "x", "pos": 2800, "lw": 2, "ls": "dash", "layer": "above", "color": "#ff6"}
            ]
        },
        "integral_hist": {"min": 0, "max": 20000, "step": 100},
        "time_hist":     {"min": 0, "max": 400,   "step": 4}
    },
    "hycal_hist": {
        "// Trigger filter + histogram binning for the HyCal cluster monitor.": "",
        "// Reconstruction knobs (min_*_energy, split_iter, ...) live in": "",
        "// reconstruction_config.json under 'hycal'.": "",
        "accept_trigger_bits": ["SSP0", "SSP1", "SSP2", "SSP3"],
        "reject_trigger_bits": ["LMS", "Alpha", "Pulser"],
        "energy_hist": {
            "min": 0,
            "max": 4000,
            "step": 10
        },
        "raw_energy_hist": {
            "// Per-event sum of all module energies (pre-clustering).": "",
            "min": 100,
            "max": 4100,
            "step": 10
        },
        "nclusters_hist": {
            "min": 0.5,
            "max": 10.5,
            "step": 1
        },
        "nblocks_hist": {
            "min": 0,
            "max": 40,
            "step": 1
        }
    },
    "lms_monitor": {
        "accept_trigger_bits": ["LMS"],
        "// time_cut: per-channel peak-time window for LMS+Alpha integral picking.": "",
        "// Independent from waveform.filter so calibration tracks aren't perturbed": "",
        "// by Waveform-Tab edits.": "",
        "time_cut": {"min": 160, "max": 220},
        "warn_threshold": 0.1,
        "warn_min_mean": 100,
        "max_history": 5000,
        "reference_channels": ["LMS1", "LMS2", "LMS3"],
        "alpha": {
            "accept_trigger_bits": ["Alpha"]
        },
        "// Gain-drift detection — compare current LMS mean against a baseline": "",
        "// .dat file produced by prad2ana_gain_monitor.  drift = current /": "",
        "// (baseline * lamp_scale), where lamp_scale cancels the LMS pulser /": "",
        "// FADC-integration scale change between baseline and current run via": "",
        "// the named reference channel.  Modules outside the [low, high] band": "",
        "// for their type are flagged with a top-priority 'drift' state (above": "",
        "// the existing rms/floor warn) so they appear at the top of the LMS": "",
        "// table and the report.  Disable by setting drift_baseline_file to an": "",
        "// empty string.": "",
        "//": "",
        "// Why per-type bounds: PbWO4 and PbGlass have very different LMS": "",
        "// coupling and PMT aging.  Healthy W modules sit within ±5% of unity,": "",
        "// while between baselines the entire G population can systematically": "",
        "// shift by 10-25%.  A single threshold either misses real W drift or": "",
        "// floods the alarm list with the G systematic.  Use the per-type keys": "",
        "// (drift_warn_low_w/high_w, drift_warn_low_g/high_g) — when set, they": "",
        "// take precedence over the shared drift_warn_low/high fallback.": "",
        "//": "",
        "// Defaults below: W = ±15% (≈3σ of healthy width, flags W691-style": "",
        "// 50% gain loss easily); G = [0.7, 1.5] to absorb the ~21% systematic": "",
        "// observed in 024352→024459 while still catching genuine outliers.": "",
        "// Re-tighten G once a fresher baseline lands and the systematic is": "",
        "// folded into the reference.": "",
        "drift_baseline_file": "gain_factor/prad_024352_LMS.dat",
        "drift_ref_channel":   "LMS2",
        "drift_warn_low_w":    0.85,
        "drift_warn_high_w":   1.15,
        "drift_warn_low_g":    0.7,
        "drift_warn_high_g":   1.5,
        "// Whole module types (matching hycal_map.json 't' field) whose drift": "",
        "// warnings should be suppressed.  The drift VALUE is still computed": "",
        "// and shown in the LMS table — only the alarm escalation is muted.": "",
        "// Default suppresses PbGlass because the 024352→024459 baseline span": "",
        "// has a ~21% systematic shift on PbGlass that would otherwise drown": "",
        "// out genuine alarms.  Remove from this list (or replace baseline)": "",
        "// once a fresher PbGlass calibration is in.": "",
        "drift_warn_suppress_types": ["PbGlass"]
    },
    "monitor_status": {
        "// Header status panel shown only in online (monitor) mode.": "",
        "// Each metric shells out to a command (typically `caget -t <chan>`)": "",
        "// and parses the first floating-point number from stdout.  An empty": "",
        "// command disables the metric.  Values <0 are displayed as N/A.": "",
        "livetime": {
            "command": "caget -t B_DAQ:PRAD:livetime",
            "unit": "%",
            "poll_sec": 3,
            "healthy": 90,
            "warning": 80
        },
        "beam": {
            "energy": {
                "command": "caget -t MBSY2C_energy",
                "unit": "MeV",
                "poll_sec": 5
            },
            "current": {
                "command": "caget -t hallb_IPM2C21A_CUR",
                "unit": "nA",
                "poll_sec": 5,
                "trip_warn_below": 0.3
            }
        }
    },
    "epics": {
        "max_history": 5000,
        "warn_threshold": 0.1,
        "alert_threshold": 0.2,
        "min_avg_points": 10,
        "mean_window": 20,
        "slots": [
            ["hallb_IPM2C24A_CUR", "hallb_IPM2C21A_CUR"],
            ["MBSY2C_energy"],
            ["TGT:PRad:Cell_P", "TGT:PRad:Chamber_P"],
            ["TGT:PRad:Cell_Body_T", "TGT:PRad:Cell_Gas_T"],
            ["hallb_IPM2C24A_XPOS", "hallb_IPM2C24A_YPOS"],
            ["hallb_IPM2C21A_XPOS", "hallb_IPM2C21A_YPOS"]
        ]
    },
    "physics": {
        "accept_trigger_bits": ["SSP0", "SSP1", "SSP2", "SSP3"],
        "beam_energy": {
            "epics_channel": "MBSY2C_energy",
            "min_valid": 100.0
        },
        "energy_angle_hist": {
            "angle_min": 0.0,
            "angle_max": 8.0,
            "angle_step": 0.2,
            "energy_min": 0.0,
            "energy_max": 4000.0,
            "energy_step": 100.0
        },
        "moller": {
            "energy_tolerance": 0.1,
            "angle_min": 1.0,
            "angle_max": 1.2,
            "xy_hist": {
                "x_min": -600.0, "x_max": 600.0, "x_step": 5.0,
                "y_min": -600.0, "y_max": 600.0, "y_step": 5.0
            }
        },
        "hycal_cluster_hit": {
            "n_clusters": 1,
            "energy_frac_min": 0.8,
            "nblocks_min": 3,
            "nblocks_max": 30,
            "xy_hist": {
                "x_min": -600.0, "x_max": 600.0, "x_step": 5.0,
                "y_min": -600.0, "y_max": 600.0, "y_step": 5.0
            }
        }
    },
    "gem": {
        "// Both gates use the parametric sigma from reconstruction_config.json:matching": "",
        "// (HyCal: PositionResolution(E); GEM: gem_pos_res[d]).  match_nsigma is": "",
        "// the multiplier on sqrt(sigma_HC^2 + sigma_GEM^2) at the residual plane.": "",
        "hycal_match": {
            "require_ep_candidate": true,
            "match_nsigma": 3.0,
            "residual_hist": {"min": -25.0, "max": 25.0, "step": 0.5}
        },
        "efficiency": {
            "// LOO per-detector tracking efficiency.  Three modes:": "",
            "//   loo-target-seed  single seed=(target→HyCal); fit=HyCal+3 OTHER GEMs.": "",
            "//   loo              GEM-seeded; fit=HyCal+3 OTHER GEMs.  Vertex-agnostic.": "",
            "//   loo-target-in    GEM-seeded; target also in fit weighted by": "",
            "//                    matching:target_pos_res in reconstruction_config.json.": "",
            "loo_mode":               "loo-target-seed",
            "// min_cluster_energy: MeV — HyCal cluster gate for the seed.": "",
            "min_cluster_energy":     500.0,
            "match_nsigma":           3.0,
            "max_chi2_per_dof":       3.5,
            "max_hits_per_detector":  50,
            "min_denom_for_eff":      20,
            "healthy":                90,
            "warning":                70,
            "// z_target_hist: distribution of inferred vertex z (DOCA of the": "",
            "// fit line to the lab z-axis, minus target_z) accumulated over": "",
            "// matched events.  Range/step in mm.": "",
            "z_target_hist":          {"min": -200.0, "max": 200.0, "step": 4.0},
            "// local_grid: per-detector eff-vs-position 2D heatmap.  nx/ny": "",
            "// bins span the full active area (xstep = det.size_x/nx).  Live": "",
            "// monitor renders this as a 2x2 panel of GEM-local heatmaps; the": "",
            "// occupied region traces the GEM/HyCal acceptance overlap.": "",
            "local_grid":             {"nx": 30, "ny": 30}
        }
    },
    "auto_report": {
        "// Master switch for the on-demand auto-report pipeline.  When": "",
        "// true, the server fires a capture_request to one alive WS": "",
        "// client on every END (or run-change fallback); that client": "",
        "// captures + uploads, server saves locally and (if": "",
        "// post_to_elog) pushes to the logbook.  Operator-controlled,": "",
        "// no UI toggle.": "",
        "enabled": true,
        "// Hard server-side guard. While false, auto-reports are saved": "",
        "// under local_save_dir but the curl --upload-file step is": "",
        "// skipped. Flip to true once the saved bodies look correct.": "",
        "post_to_elog": true,
        "// Required.  Each capture is mirrored under": "",
        "// <local_save_dir>/run_NNNNNN/ as report_<UTC>.xml + the PNG": "",
        "// attachments decoded out of the XML.  An aggregate": "",
        "// summary.json sits at the top of the dir with one entry per": "",
        "// auto-post attempt (success or failure).": "",
        "local_save_dir": "/home/clasrun/prad2_daq/monitor/reports",
        "// Hard rate limit between auto posts (ms).  Catches": "",
        "// near-simultaneous duplicate triggers (END + run-change).": "",
        "min_interval_ms": 300000,
        "// Logbook target.  Switch to TLOG while testing.": "",
        "elog": {
            "url": "https://logbooks.jlab.org",
            "logbook": "PRADLOG",
            "author": "clasrun",
            "// Tags must come from the logbook's enumerated set.": "",
            "// PRADLOG accepts (subset): Autolog, DAQ, Detector,": "",
            "// Analysis, Readme, BeamEnergy, Beamline, …  Use 'Autolog'": "",
            "// for the auto-generated reports.": "",
            "tags": ["Autolog", "DAQ"],
            "cert": "/home/clasrun/prad2_daq/monitor/keys/elog-cert.pem",
            "key":  "/home/clasrun/prad2_daq/monitor/keys/elog-key.pem"
        }
    },
    "color_ranges": {
        "dq:integral":  [0, 10000],
        "dq:height":    [0, 1000],
        "dq:count":     [0, 10],
        "dq:time":      [0, 400],
        "dq:pedestal":  [0, 500],
        "dq:occupancy": [0, 100],
        "cluster:energy": [0, 1000],
        "lms:mean":     [0, 5000],
        "lms:rms_frac": [0, 0.2]
    }
 }
