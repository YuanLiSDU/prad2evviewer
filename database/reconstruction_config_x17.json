{
    "// Reconstruction config — runinfo pointer + cluster/hit-level knobs.": "",
    "// Loaded by prad2_server -r and by analysis tools (Replay, matching, det_calib).": "",
    "// Sister files: monitor_config.json (GUI) and daq_config.json (DAQ + raw decoding).": "",

    "runinfo": "runinfo/general.json",

    "hycal": {
        "// HyCal island clustering — mirrors fdec::ClusterConfig defaults.": "",
        "min_module_energy":  1.0,
        "min_center_energy":  10.0,
        "min_cluster_energy": 50.0,
        "min_cluster_size":   1,
        "corner_conn":        false,
        "non_linear_corr":    true,
        "split_iter":         6,
        "least_split":        0.01,
        "log_weight_thres":   3.6,
        "// Multi-pulse seed-time gate (ns).  ≤0 = legacy single-pulse mode.": "",
        "// >0 lets HyCalCluster.AddHit be called once per analyzer pulse;": "",
        "// FormClusters then groups neighbour pulses within ±this window of": "",
        "// the seed pulse.": "",
        "seed_time_window":   16.0
    },

    "gem": {
        "// Per-detector clustering + XY-matching knobs.  'default' applies to": "",
        "// every detector; add '0'/'1'/'2'/'3' objects to override individual": "",
        "// detectors (overrides shallow-merge over 'default').": "",
        "default": {
            "min_cluster_hits":    1,
            "max_cluster_hits":    20,
            "consecutive_thres":   1,
            "split_thres":         14.0,
            "cross_talk_width":    2.0,
            "charac_dists":        [],
            "match_mode":          1,
            "match_adc_asymmetry": 0.7,
            "match_time_diff":     50.0,
            "match_ts_period":     25.0,
            "// Strip-level cuts (migrated from gem_map.json):": "",
            "reject_first_timebin": true,
            "reject_last_timebin":  false,
            "min_peak_adc":         30.0,
            "min_sum_adc":          60.0
        }
    },

    "matching": {
        "// HyCal-GEM matching: position-resolution inputs used to build the": "",
        "// target gas distribution, used as resolution to allow uncertainties of target point": "",
        "target_pos_res": [0.5, 0.5, 2.0],
        "// search window.  hycal_pos_res = [A, B, C] (mm) feeds": "",
        "//   sigma_HC(E) = sqrt((A/sqrt(E_GeV))^2 + (B/E_GeV)^2 + C^2)": "",
        "hycal_pos_res": [3.6, 0.0, 0.0],
        "// gem_pos_res = per-detector sigma in mm (ordered by detector id 0..3).": "",
        "// gem_pos_res is high now (supposed to be < 0.1 mm) to include coordinate shifts.": "",
        "gem_pos_res":   [0.5, 0.5, 0.5, 0.5]
    }
}
