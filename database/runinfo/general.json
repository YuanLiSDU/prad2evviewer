{
    "// Run-period geometry + calibration metadata.  Three tiers:":                                                                  "",
    "//   defaults       — fields that almost never change (invariants).":                                                            "",
    "//   configurations — sparse period entries; each chains on top of":                                                             "",
    "//                    the previous one (and over defaults).":                                                                    "",
    "//   gem_pedestals  — per-run pedestal/CM table; lookup is independent":                                                         "",
    "//                    of configurations (largest from_run <= run_num).":                                                         "",
    "//":                                                                                                                             "",
    "// `from_run` is the trigger key; `run_number` is accepted as an alias for":                                                     "",
    "// backward-compat with older runinfo files.":                                                                                   "",
    "//":                                                                                                                             "",
    "// Detector positions live in `defaults` (the latest precise survey), so":                                                       "",
    "// every period reads them by default.  Configurations may still override":                                                      "",
    "// hycal.position / gem.detectors[id].position when a future period gets":                                                       "",
    "// its own survey — per-id GEM entries merge by id, so an override that":                                                        "",
    "// only sets position for one detector keeps the others on defaults.":                                                           "",
    "//":                                                                                                                             "",
    "// Chained semantics: anything an earlier entry overrides stays applied":                                                        "",
    "// to later entries unless they explicitly re-override.  Keep `defaults`":                                                       "",
    "// for fields that genuinely never change; period-volatile fields should":                                                       "",
    "// be set explicitly in every period entry that needs them.":                                                                    "",

    "defaults": {
