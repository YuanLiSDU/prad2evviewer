{
    "// Run-period geometry + calibration metadata.  Three tiers:":                                                                  "",
    "//   defaults       — fields that almost never change (invariants).":                                                            "",
    "//   configurations — sparse period entries; each chains on top of":                                                             "",
    "//                    the previous one (and over defaults).":                                                                    "",
    "//   gem_pedestals  — per-run pedestal/CM table; lookup is independent":                                                         "",
    "//                    of configurations (largest from_run <= run_num).":                                                         "",
    "//":                                                                                                                             "",
    "// `from_run` is the trigger key; `run_number` is accepted as an alias for":                                                     "",
    "// backward-compat with older runinfo files.":                                                                                   "",
    "//":                                                                                                                             "",
    "// Detector positions live in `defaults` (the latest precise survey), so":                                                       "",
    "// every period reads them by default.  Configurations may still override":                                                      "",
    "// hycal.position / gem.detectors[id].position when a future period gets":                                                       "",
    "// its own survey — per-id GEM entries merge by id, so an override that":                                                        "",
    "// only sets position for one detector keeps the others on defaults.":                                                           "",
    "//":                                                                                                                             "",
    "// Chained semantics: anything an earlier entry overrides stays applied":                                                        "",
    "// to later entries unless they explicitly re-override.  Keep `defaults`":                                                       "",
    "// for fields that genuinely never change; period-volatile fields should":                                                       "",
    "// be set explicitly in every period entry that needs them.":                                                                    "",

    "defaults": {
        "calibration":   {"default_adc2mev": 0.12},
        "target":        [0.0, 0.0, 0.0],
        "hycal": {
            "position":  [-0.70, -1.83, 6269.81], "tilting":   [0.0, 0.0, 0.0]
        },
        "gem": {
            "detectors": [
                {"id": 0, "position": [-229.16, -2.2, 5817.0], "tilting": [180.0, 0.0,   0.0]},
                {"id": 1, "position": [ 226.35, -1.4, 5853.8], "tilting": [180.0, 0.0, 180.0]},
                {"id": 2, "position": [-229.10, -1.0, 5414.0], "tilting": [180.0, 0.0,   0.0]},
                {"id": 3, "position": [ 226.53, -1.2, 5458.0], "tilting": [180.0, 0.0, 180.0]}
            ]
        },
        "matching":      {"radius": 15.0, "use_square_cut": true}
    },

    "configurations": [
        {
            "from_run":    0,
            "beam_energy": 2108.8,
            "calibration": {"file": "calibration/calibration_factor_2p1.json"},
            "time_cuts":   {"hc_time_window": [60.0, 400.0]},
            "gain_factor": {"data_dir": "", 
            "ref_run": 23915}
        },
        {
            "from_run":    24185,
            "beam_energy": 3488.43,
            "calibration": {"file": "calibration/calibration_factor_3p5_5by5.json"},
            "time_cuts":   {"hc_time_window": [130.0, 200.0]},
            "gain_factor": {
                "data_dir": "",
                "ref_run":  24512
            }
        },
        {
            "// Reuses the 24185 calibration, time cuts, and gain reference":  "",
            "// — chained inheritance fills in the rest.":                     "",
            "from_run":    24551,
            "beam_energy": 728.9
        },
        {
            "from_run":    24670,
            "beam_energy": 3488.43,
            "calibration": {"file": "calibration/calibration_factor_3p5_5by5.json"},
            "time_cuts":   {"hc_time_window": [130.0, 200.0]},
            "gain_factor": {
                "data_dir": "",
                "ref_run":  24512
            }
        }
    ],

    "// Per-run GEM pedestals + common-mode range.  Bumping pedestals on a":                                                          "",
    "// new run only requires appending one row here — no need to touch":                                                             "",
    "// the configurations array.":                                                                                                   "",
    "gem_pedestals": [
        {"from_run":     0, "pedestal_file": "gem_peds/peds_24177.txt",    "common_mode_file": "gem_peds/cm_24177.txt"},
        {"from_run": 24023, "pedestal_file": "gem_peds/gem_ped_24023.dat", "common_mode_file": "gem_peds/CommonModeRange_24023.txt"},
        {"from_run": 24162, "pedestal_file": "gem_peds/gem_ped_24162.dat", "common_mode_file": "gem_peds/CommonModeRange_24162.txt"},
        {"from_run": 24177, "pedestal_file": "gem_peds/gem_ped_24177.dat", "common_mode_file": "gem_peds/CommonModeRange_24177.txt"},
        {"from_run": 24436, "pedestal_file": "gem_peds/gem_ped_24436.dat", "common_mode_file": "gem_peds/CommonModeRange_24436.txt"},
        {"from_run": 24495, "pedestal_file": "gem_peds/gem_ped_24495.dat", "common_mode_file": "gem_peds/CommonModeRange_24495.txt"},
        {"from_run": 24535, "pedestal_file": "gem_peds/gem_ped_24535.dat", "common_mode_file": "gem_peds/CommonModeRange_24535.txt"}
    ]
}
